# ─── Commit: Professional Security & Monorepo Ignores ───
# What this does: Protects your Groq keys and prevents 100MB+ node_modules from uploading.
# Interview insight: This shows a high level of "Operational Discipline" and security awareness.

# Standard Node Ignores
node_modules/
dist/
build/
.next/
.vercel/

# Environment Secrets (CRITICAL SECURITY)
.env
.env.local
.env.*.local
*.env
! .env.example

# Service Specific Ignores
Backend/node_modules/
Frontend/node_modules/
Frontend/dist/
Frontend/build/

# Media & Storage
uploads/
temp/
*.log

# IDE & OS Files
.DS_Store
Thumbs.db
.vscode/
.idea/
.project
.settings

# Extraction Folders (Leftovers from migration/backup)
extracted_final/
extracted_temp/
