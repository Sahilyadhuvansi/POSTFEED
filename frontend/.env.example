# API Configuration
VITE_API_URL=http://localhost:3001
VITE_NODE_ENV=development

# YouTube Data API v3 — FREE from console.cloud.google.com
# Steps: New Project → Enable "YouTube Data API v3" → Credentials → Create API Key
# Free quota: 10,000 requests/day (= ~100 searches/day), no credit card needed
VITE_YOUTUBE_API_KEY=your_youtube_data_api_v3_key_here

# Media & Assets
VITE_DEFAULT_AVATAR=https://www.gravatar.com/avatar/?d=mp&f=y&s=200
VITE_IMAGEKIT_UPLOAD_URL=https://upload.imagekit.io/api/v1/files/upload
